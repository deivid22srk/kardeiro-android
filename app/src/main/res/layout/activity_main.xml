<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/kardeiro_background"
    android:fillViewport="true">

    <com.kardeiro.library.views.KardeiroLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:kardeiro_insetBottom="32dp"
        app:kardeiro_insetEnd="16dp"
        app:kardeiro_insetStart="16dp"
        app:kardeiro_spacing="16dp">

        <com.kardeiro.library.views.KardeiroHeader
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:kardeiro_header_subtitle="@string/header_subtitle"
            app:kardeiro_header_title="@string/header_title" />

        <com.kardeiro.library.views.KardeiroCard
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:kardeiro_borderWidth="1dp"
            app:kardeiro_cornerRadius="20dp"
            app:kardeiro_elevation="6dp"
            app:kardeiro_padding="20dp"
            app:kardeiro_shadowEnabled="true">

            <com.kardeiro.library.views.KardeiroLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:kardeiro_spacing="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/card_title"
                        android:textAppearance="@style/TextAppearance.Kardeiro.Title" />

                    <com.kardeiro.library.views.KardeiroBadge
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/badge_new"
                        app:kardeiro_badgeSize="medium"
                        app:kardeiro_badgeText="@string/badge_new" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/card_body"
                    android:textAppearance="@style/TextAppearance.Kardeiro.Body" />
            </com.kardeiro.library.views.KardeiroLayout>
        </com.kardeiro.library.views.KardeiroCard>

        <com.kardeiro.library.views.KardeiroCard
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:kardeiro_borderWidth="1dp"
            app:kardeiro_cornerRadius="20dp"
            app:kardeiro_elevation="6dp"
            app:kardeiro_padding="20dp">

            <com.kardeiro.library.views.KardeiroLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:kardeiro_spacing="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Entrar na conta"
                    android:textAppearance="@style/TextAppearance.Kardeiro.Title" />

                <com.kardeiro.library.views.KardeiroTextField
                    android:id="@+id/email_field"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:kardeiro_fieldHelperText="@string/helper_email"
                    app:kardeiro_fieldHint="@string/hint_email"
                    app:kardeiro_fieldLabel="@string/label_email" />

                <com.kardeiro.library.views.KardeiroTextField
                    android:id="@+id/password_field"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:kardeiro_fieldHint="@string/hint_password"
                    app:kardeiro_fieldLabel="@string/label_password" />

                <com.kardeiro.library.views.KardeiroButton
                    android:id="@+id/btn_login"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="@string/action_login"
                    app:kardeiro_buttonRadius="14dp"
                    app:kardeiro_buttonStyle="filled" />

                <com.kardeiro.library.views.KardeiroButton
                    android:id="@+id/btn_create"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="@string/action_create_account"
                    app:kardeiro_buttonRadius="14dp"
                    app:kardeiro_buttonStyle="tonal" />

                <com.kardeiro.library.views.KardeiroButton
                    android:id="@+id/btn_forgot"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="@string/action_forgot"
                    app:kardeiro_buttonRadius="14dp"
                    app:kardeiro_buttonStyle="text" />
            </com.kardeiro.library.views.KardeiroLayout>
        </com.kardeiro.library.views.KardeiroCard>

        <com.kardeiro.library.views.KardeiroCard
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:kardeiro_borderWidth="1dp"
            app:kardeiro_cornerRadius="20dp"
            app:kardeiro_elevation="6dp"
            app:kardeiro_padding="20dp">

            <com.kardeiro.library.views.KardeiroLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:kardeiro_spacing="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Planos"
                    android:textAppearance="@style/TextAppearance.Kardeiro.Title" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <com.kardeiro.library.views.KardeiroBadge
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:text="@string/badge_new"
                        app:kardeiro_badgeSize="small" />

                    <com.kardeiro.library.views.KardeiroBadge
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/badge_premium"
                        app:kardeiro_badgeSize="medium"
                        app:kardeiro_badgeTextColor="@color/kardeiro_on_accent" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Conheça os planos premium com identidade visual Kardeiro — quente, moderna e acolhedora."
                    android:textAppearance="@style/TextAppearance.Kardeiro.Body" />
            </com.kardeiro.library.views.KardeiroLayout>
        </com.kardeiro.library.views.KardeiroCard>
    </com.kardeiro.library.views.KardeiroLayout>
</ScrollView>
